# ── Stripe ────────────────────────────────────────────────────────
# Stripe Publishable Key (Frontend - öffentlich)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Secret Key (nur Backend/Vercel Functions - NIEMALS im Frontend!)
STRIPE_SECRET_KEY=sk_test_...

# ── Datenbank ─────────────────────────────────────────────────────
# Supabase (empfohlen) oder eigene DB
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Warenwirtschaft API ───────────────────────────────────────────
# URL des Warenwirtschaftssystems (z.B. Weclapp, Sage)
API_WARENWIRTSCHAFT_URL=https://api.dein-laden.de
API_WARENWIRTSCHAFT_KEY=your-api-key

# ── E-Mail (Bestellbestätigung) ───────────────────────────────────
RESEND_API_KEY=re_...

# ── App ───────────────────────────────────────────────────────────
VITE_APP_URL=https://deine-domain.de
